MODULE    = winebroadway.drv
UNIXLIB   = winebroadway.so
IMPORTS   = ntoskrnl
UNIX_CFLAGS  = $(BROADWAY_CLIENT_CFLAGS)
UNIX_LIBS  = -lwin32u $(PTHREAD_LIBS) $(BROADWAY_CLIENT_LIBS)

C_SRCS = \
	dllmain.c \
	init.c \
	display.c \
	broadway-buffer.c \
	broadway-server.c

