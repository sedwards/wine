MODULE    = winebroadway.drv
UNIXLIB   = winebroadway.so
IMPORTS   = uuid user32 gdi32 win32u
DELAYIMPORTS = comctl32 ole32 shell32 imm32
UNIX_CFLAGS  = $(BROADWAY_CLIENT_CFLAGS)
UNIX_LIBS  = -lwin32u -lbroadway-wine $(PTHREAD_LIBS) $(BROADWAY_CLIENT_LIBS)

C_SRCS = \
	broadwaydrv_main.c \
	dllmain.c \
	init.c
	gdk/bdfcursor.c
        gdk/gdkcursor-win32.c
        gdk/gdkdevicemanager-win32.c
        gdk/gdkdevice-virtual.c
        gdk/gdkdevice-win32.c
        gdk/gdkdevice-winpointer.c
        gdk/gdkdevice-wintab.c
        gdk/gdkdisplaymanager-win32.c
        gdk/gdkdisplay-win32.c
        gdk/gdkdnd-win32.c
        gdk/gdkevents-win32.c
        gdk/gdkgeometry-win32.c
        gdk/gdkglcontext-win32.c
        gdk/gdkglobals-win32.c
        gdk/gdkkeys-win32.c
        gdk/gdkkeys-win32-impl.c
        gdk/gdkkeys-win32-impl-wow64.c
        gdk/gdkmain-win32.c
        gdk/gdkmonitor-win32.c
        gdk/gdkproperty-win32.c
        gdk/gdkscreen-win32.c
        gdk/gdkselection-win32.c
        gdk/gdktestutils-win32.c
        gdk/gdkwin32id.c
        gdk/gdkwin32langnotification.c
        gdk/gdkwindow-win32.c

