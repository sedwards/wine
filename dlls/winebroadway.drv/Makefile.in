MODULE    = winebroadway.drv
UNIXLIB   = winebroadway.so
IMPORTS   = uuid rpcrt4 user32 gdi32 win32u
DELAYIMPORTS = comctl32 ole32 shell32 imm32
UNIX_CFLAGS  = $(BROADWAY_CLIENT_CFLAGS) -Wno-implicit-function-declaration
UNIX_LIBS  = -lwin32u -lbroadway-wine $(PTHREAD_LIBS) $(BROADWAY_CLIENT_LIBS)

C_SRCS = \
	dllmain.c \
	broadway-server.c \
	broadwaydrv_main.c \
	init.c \
	gdi.c \
	surface.c \
	window.c \
	clipboard.c \
	systray.c

